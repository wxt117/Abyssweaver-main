        <level>5</level>
        <order>1</order>
        <psyfocusCost>0.25</psyfocusCost>
        <entropyGain>20</entropyGain>
      </li>
      <li Class="VPE_MyExtension.AbilityExtension_FleshHealing">
        <healInjuries>true</healInjuries>
        <healPermanentInjuries>true</healPermanentInjuries>
        <replaceMissingParts>true</replaceMissingParts>
        <fallbackReplacement>VPEMYX_AbyssweaverOrgan</fallbackReplacement>
